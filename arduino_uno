#include <Servo.h>

// 1. Instancia os 3 servos do circuito
Servo servoU;   // Conectado ao pino 6
Servo servoD;   // Conectado ao pino 5
Servo servoT;  // Conectado ao pino 3

const int BT1 = 13;
const int BT2 = 12;

void setup() {
  pinMode(BT1, INPUT_PULLUP);
  pinMode(BT2, INPUT_PULLUP);
  servoU.attach(6); //attach é o sinal do motor no arduino
}

void loop()
{
    if (digitalRead(BT1) == HIGH)
{
    servoU.write(180);  // sentido 1
}
else if (digitalRead(BT2) == HIGH)
{
    servoU.write(0);    // sentido 2
}
else
{
    servoU.write(90);   // parado
}
}
